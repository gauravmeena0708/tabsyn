#!/usr/bin/env python
"""TabSyn plugin `train` endpoint: JSON request on stdin -> JSON result on stdout.

Ported from the host's ``wrappers/tabsyn_wrapper.py`` (train path). TabSyn is
unconditional: it trains a VAE then a diffusion model for the named dataset under
``sub/tabsyn/tabsyn/{vae/ckpt,ckpt}/<dataset>`` (reusing existing checkpoints),
then writes ``model_dir/meta.json`` describing the trained artifact.

Contract discipline: the single JSON result is the ONLY thing on stdout; every
log line and all upstream-process output go to stderr.
"""
from __future__ import annotations

import datetime
import json
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

import pandas as pd

TABSYN_ROOT = Path(__file__).resolve().parents[1]
TRAIN_LOCK_DIR = ".train_lock"
VAE_EPOCHS = 4000
DIFFUSION_EPOCHS = 10001


def log(msg: str) -> None:
    print(f"[tabsyn] {msg}", file=sys.stderr, flush=True)


def gpu_index(device: str) -> int:
    if device and device.startswith("cuda") and ":" in device:
        return int(device.split(":", 1)[1])
    return 0


class ModelDirLock:
    def __init__(self, model_dir: Path, poll_seconds: float = 2.0, timeout_seconds: float = 7200.0):
        self.lock_dir = model_dir / TRAIN_LOCK_DIR
        self.poll_seconds = poll_seconds
        self.timeout_seconds = timeout_seconds

    def __enter__(self):
        deadline = time.monotonic() + self.timeout_seconds
        while True:
            try:
                os.mkdir(self.lock_dir)
                return self
            except FileExistsError:
                if time.monotonic() >= deadline:
                    raise TimeoutError(
                        f"Could not acquire TabSyn training lock {self.lock_dir} after "
                        f"{self.timeout_seconds:.0f}s."
                    )
                time.sleep(self.poll_seconds)

    def __exit__(self, exc_type, exc, tb):
        try:
            os.rmdir(self.lock_dir)
        except FileNotFoundError:
            pass


def run_tabsyn(args: list[str]) -> None:
    cmd = [sys.executable, *args]
    log("$ " + " ".join(cmd))
    # Inherit nothing onto our stdout: upstream chatter must land on stderr.
    subprocess.run(cmd, cwd=TABSYN_ROOT, check=True, stdout=sys.stderr, stderr=sys.stderr)


def processed_data_ready(dataset: str) -> bool:
    data_dir = TABSYN_ROOT / "data" / dataset
    required = ["info.json", "train.csv", "test.csv",
                "X_num_train.npy", "X_cat_train.npy", "y_train.npy"]
    return all((data_dir / name).exists() for name in required)


def raw_data_ready(dataset: str) -> bool:
    info_path = TABSYN_ROOT / "data" / "Info" / f"{dataset}.json"
    if not info_path.exists():
        return False
    info = json.loads(info_path.read_text(encoding="utf-8"))
    raw_paths = [info.get("data_path"), info.get("test_path")]
    return all(not rel or (TABSYN_ROOT / rel).exists() for rel in raw_paths)


def build_tabsyn_info(
    dataset: str,
    df: "pd.DataFrame",
    num_cols: list[str],
    cat_cols: list[str],
    label_col: str,
    data_path: str,
    test_path: str,
    test_num: int,
) -> dict:
    """Build TabSyn's ``data/Info/<dataset>.json`` config from a framework train
    DataFrame. Pure function: column order, num/cat/target indices, and per-column
    type tags are derived from the passed schema (mirrors register_tabsyn_dataset)."""
    columns = list(df.columns)
    num_col_idx = [columns.index(c) for c in num_cols]
    cat_col_idx = [columns.index(c) for c in cat_cols]
    target_col_idx = [columns.index(label_col)]

    target_unique = df[label_col].nunique()
    if pd.api.types.is_numeric_dtype(df[label_col]) and target_unique > 10:
        task_type = "regression"
    elif target_unique == 2:
        task_type = "binclass"
    else:
        task_type = "multiclass"

    column_info = {c: ("float" if c in num_cols else "str") for c in columns}

    return {
        "name": dataset,
        "task_type": task_type,
        "header": 0,
        "column_names": columns,
        "num_col_idx": num_col_idx,
        "cat_col_idx": cat_col_idx,
        "target_col_idx": target_col_idx,
        "file_type": "csv",
        "data_path": data_path,
        "test_path": test_path,
        "column_info": column_info,
        "train_num": int(len(df)),
        "test_num": int(test_num),
    }


def _resolve_column_types(
    df: "pd.DataFrame", label_col: str, train_csv: Path, info_json_path: str | None
) -> tuple[list[str], list[str]]:
    """Resolve numerical/categorical column lists for ``df``.

    Prefer the framework ``info.json`` (explicit ``numerical_columns`` /
    ``categorical_columns``) — supplied via ``info_json_path`` or the sibling file
    next to ``train_csv`` — and fall back to pandas dtype inference."""
    columns = list(df.columns)
    info_path = Path(info_json_path) if info_json_path else (train_csv.parent / "info.json")
    if info_path.exists():
        fw = json.loads(info_path.read_text(encoding="utf-8"))
        num_cols = [c for c in fw.get("numerical_columns", []) if c in columns]
        cat_cols = [c for c in fw.get("categorical_columns", []) if c in columns and c != label_col]
        if num_cols or cat_cols:
            return num_cols, cat_cols
    num_cols, cat_cols = [], []
    for c in columns:
        if c == label_col:
            continue
        if pd.api.types.is_numeric_dtype(df[c]):
            num_cols.append(c)
        else:
            cat_cols.append(c)
    return num_cols, cat_cols


def prepare_processed_data_from_train_csv(
    dataset: str, train_csv: Path, label_column: str | None, info_json_path: str | None
) -> None:
    """Build TabSyn's processed dataset from the framework-supplied ``train_csv``
    (and its sibling ``test.csv``/``info.json``), then run upstream
    ``process_dataset.py``. This is what makes TabSyn train on the same data the
    rest of the framework uses, rather than its own upstream-downloaded copy."""
    if not train_csv.exists():
        raise FileNotFoundError(f"train_csv not found: {train_csv}")
    train_df = pd.read_csv(train_csv)
    columns = list(train_df.columns)

    info_path = Path(info_json_path) if info_json_path else (train_csv.parent / "info.json")
    label_col = label_column
    if not label_col and info_path.exists():
        label_col = json.loads(info_path.read_text(encoding="utf-8")).get("target_column")
    if not label_col or label_col not in columns:
        raise ValueError(
            f"label column {label_col!r} not resolvable in {dataset} columns: {columns}"
        )

    num_cols, cat_cols = _resolve_column_types(train_df, label_col, train_csv, info_json_path)

    data_dir = TABSYN_ROOT / "data" / dataset
    data_dir.mkdir(parents=True, exist_ok=True)
    raw_train = data_dir / f"{dataset}_train.csv"
    shutil.copyfile(train_csv, raw_train)

    fw_test = train_csv.parent / "test.csv"
    if fw_test.exists():
        raw_test = data_dir / f"{dataset}_test.csv"
        shutil.copyfile(fw_test, raw_test)
        test_path = str(raw_test.relative_to(TABSYN_ROOT))
        test_num = int(len(pd.read_csv(fw_test)))
    else:
        # process_dataset.py carves an internal 90/10 split when test_path is empty.
        test_path = ""
        test_num = int(len(train_df) * 0.1)

    info = build_tabsyn_info(
        dataset, train_df, num_cols, cat_cols, label_col,
        data_path=str(raw_train.relative_to(TABSYN_ROOT)),
        test_path=test_path, test_num=test_num,
    )
    info_dir = TABSYN_ROOT / "data" / "Info"
    info_dir.mkdir(parents=True, exist_ok=True)
    (info_dir / f"{dataset}.json").write_text(json.dumps(info, indent=4))
    log(f"Built TabSyn Info for '{dataset}' from {train_csv}")
    # process_dataset.py only regenerates test.data when absent; a stale cache
    # from an earlier source CSV would otherwise shadow the freshly-copied data.
    stale_test_data = data_dir / "test.data"
    if stale_test_data.exists():
        stale_test_data.unlink()
    run_tabsyn(["process_dataset.py", "--dataname", dataset])
    if not processed_data_ready(dataset):
        raise RuntimeError(f"TabSyn processing did not create required files for '{dataset}'")


def ensure_processed_data(dataset: str) -> None:
    """Legacy path: build from TabSyn's own ``data/Info`` config + upstream raw
    download. Used only when no ``train_csv`` is supplied (off the framework path)."""
    if processed_data_ready(dataset):
        return
    info_path = TABSYN_ROOT / "data" / "Info" / f"{dataset}.json"
    if not info_path.exists():
        raise FileNotFoundError(
            f"TabSyn has no data/Info entry for dataset '{dataset}'. "
            "Add a TabSyn-compatible data config before using this plugin."
        )
    if not raw_data_ready(dataset):
        log("Raw TabSyn data missing; running upstream download_dataset.py")
        run_tabsyn(["download_dataset.py"])
    (TABSYN_ROOT / "data" / dataset).mkdir(parents=True, exist_ok=True)
    log(f"Processing dataset '{dataset}' with upstream process_dataset.py")
    run_tabsyn(["process_dataset.py", "--dataname", dataset])
    if not processed_data_ready(dataset):
        raise RuntimeError(f"TabSyn processing did not create required files for '{dataset}'")


def vae_ready(dataset: str) -> bool:
    ckpt = TABSYN_ROOT / "tabsyn" / "vae" / "ckpt" / dataset
    return all((ckpt / n).exists() for n in ("encoder.pt", "decoder.pt", "train_z.npy"))


def diffusion_ready(dataset: str) -> bool:
    return (TABSYN_ROOT / "tabsyn" / "ckpt" / dataset / "model.pt").exists()


def train_if_needed(dataset: str, gpu: int, model_dir: Path) -> dict | None:
    model_dir.mkdir(parents=True, exist_ok=True)
    training_resources: dict | None = None
    with ModelDirLock(model_dir):
        needs_vae = not vae_ready(dataset)
        needs_diffusion = not diffusion_ready(dataset)
        if needs_vae or needs_diffusion:
            start = time.monotonic()
            if needs_vae:
                log(f"Training VAE for {dataset}")
                run_tabsyn(["main.py", "--dataname", dataset, "--method", "vae",
                            "--mode", "train", "--gpu", str(gpu), "--epochs", str(VAE_EPOCHS)])
            else:
                log(f"Reusing existing VAE checkpoint for {dataset}")
            if needs_diffusion:
                log(f"Training diffusion model for {dataset}")
                run_tabsyn(["main.py", "--dataname", dataset, "--method", "tabsyn",
                            "--mode", "train", "--gpu", str(gpu), "--epochs", str(DIFFUSION_EPOCHS)])
            else:
                log(f"Reusing existing diffusion checkpoint for {dataset}")
            elapsed = time.monotonic() - start
            training_resources = {
                "vae_trained": needs_vae, "diffusion_trained": needs_diffusion,
                "vae_epochs": VAE_EPOCHS, "diffusion_epochs": DIFFUSION_EPOCHS,
                "training_seconds": elapsed, "model_training_seconds": elapsed,
            }
        else:
            log(f"Reusing existing VAE + diffusion checkpoints for {dataset}")
    return training_resources


def main() -> int:
    req = json.load(sys.stdin)
    dataset = req["dataset"]
    model_dir = Path(req["output_model_dir"])
    gpu = gpu_index(req.get("device", "cuda"))
    train_csv = Path(req["train_csv"]) if req.get("train_csv") else None

    if not TABSYN_ROOT.exists():
        raise FileNotFoundError(f"TabSyn checkout not found at {TABSYN_ROOT}")

    if train_csv is not None:
        prepare_processed_data_from_train_csv(
            dataset, train_csv, req.get("label_column"), req.get("info_json_path")
        )
    else:
        ensure_processed_data(dataset)
    training_resources = train_if_needed(dataset, gpu, model_dir)

    columns = None
    if train_csv and train_csv.exists():
        columns = list(pd.read_csv(train_csv, nrows=0).columns)

    meta = {
        "schema_version": "1.0",
        "method": req["method"],
        "dataset": dataset,
        "label_column": req.get("label_column"),
        "columns": columns or [],
        "trained_at": datetime.datetime.utcnow().isoformat() + "Z",
        "sdcontract_core_version": "1.0",
        # Method-specific extras (read by ui2 artifacts + the generate endpoint):
        "tabsyn_root": str(TABSYN_ROOT),
        "processed_data_dir": str(TABSYN_ROOT / "data" / dataset),
        "vae_checkpoint_dir": str(TABSYN_ROOT / "tabsyn" / "vae" / "ckpt" / dataset),
        "diffusion_checkpoint_dir": str(TABSYN_ROOT / "tabsyn" / "ckpt" / dataset),
        "train_csv": str(train_csv) if train_csv else None,
    }
    # Carry forward training_resources and trained_at across reuse runs if previously recorded.
    meta_path = model_dir / "meta.json"
    if training_resources is None and meta_path.exists():
        try:
            old_meta = json.loads(meta_path.read_text())
            training_resources = old_meta.get("training_resources")
            if "trained_at" in old_meta:
                meta["trained_at"] = old_meta["trained_at"]
        except Exception:
            training_resources = None
    if training_resources:
        meta["training_resources"] = training_resources
    meta_path.write_text(json.dumps(meta, indent=2))

    print(json.dumps({"ok": True, "model_dir": str(model_dir), "message": ""}))
    return 0


if __name__ == "__main__":
    sys.exit(main())
